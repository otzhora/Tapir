{
  "name": "tapir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:desktop": "npm --workspace @tapir/desktop run dev",
    "dev:with-test-projects": "node scripts/dev-with-test-projects.mjs",
    "build": "npm run build --workspaces",
    "rebuild:native:electron": "npm --workspace @tapir/desktop run rebuild:native",
    "rebuild:native:node": "npm rebuild better-sqlite3",
    "test": "node scripts/test.mjs",
    "test:workspaces": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "^3.2.6"
  },
  "allowScripts": {
    "electron@42.5.0": true,
    "better-sqlite3@12.11.1": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
